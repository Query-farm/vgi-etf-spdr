# name: test/sql/products.test
# description: spdr.products — base table: typed schema (network-free) + live catalog invariants.
# group: [sql]

require-env VGI_TEST_WORKER

statement ok
ATTACH 'spdr' AS sp (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET search_path='sp.main';

# --- Schema: DESCRIBE binds only (no network), so these are fully deterministic. ---
# `products` is a base TABLE — query it with no parentheses.

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM sp.products) WHERE column_name = 'ticker';
----
VARCHAR

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM sp.products) WHERE column_name = 'net_assets';
----
DOUBLE

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM sp.products) WHERE column_name = 'inception_date';
----
DATE

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM sp.products) WHERE column_name = 'expense_ratio_percent';
----
DOUBLE

# --- Live invariants: these hit SSGA. Assert shape, not exact (moving) values. ---

# The catalog has many funds; filter with WHERE.
query I
SELECT (count(*) > 50)::INT FROM sp.products;
----
1

# SPY (SPDR S&P 500 ETF Trust) is present with a non-negative expense ratio — via a WHERE.
query I
SELECT (count(*) = 1)::INT FROM sp.products WHERE ticker = 'SPY' AND expense_ratio_percent >= 0;
----
1

# Asset class is populated for the lineup (from the fund-finder categories tree).
query I
SELECT (count(DISTINCT asset_class) >= 1)::INT FROM sp.products WHERE asset_class IS NOT NULL;
----
1
